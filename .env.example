# Required
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_here

# Optional – defaults shown
BASE_DOMAIN=thesoftware.dev
API_SECRET_KEY=change_me_in_production
POSTGRES_PASSWORD=arcus

# JWT authentication (change in production!)
JWT_SECRET_KEY=change_me_jwt_secret_in_production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email / SMTP (leave empty to log emails instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@arcus.local
SMTP_USE_TLS=true
